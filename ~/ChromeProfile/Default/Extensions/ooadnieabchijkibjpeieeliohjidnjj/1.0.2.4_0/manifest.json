{
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "content.js" ],
      "matches": [ "http://*.navercorp.com/*", "https://*.navercorp.com/*", "https://*.naver.com/*" ],
      "run_at": "document_start"
   } ],
   "description": "네이버 동영상 서비스 이용을 위한 확장 프로그램",
   "externally_connectable": {
      "matches": [ "http://*.navercorp.com/*", "https://*.navercorp.com/*", "https://*.naver.com/*" ]
   },
   "host_permissions": [ "http://*.navercorp.com/*", "https://*.navercorp.com/*", "https://*.naver.com/*" ],
   "icons": {
      "128": "icon.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "네이버 동영상 플러그인",
   "permissions": [ "activeTab", "nativeMessaging" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.2.4"
}
